{
  "name": "tft-modular",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "test": "pnpm -r test",
    "test:loader": "pnpm --filter @tft/plugin-loader test",
    "build:wasm": "wasm-pack build crates/engine-wasm --target web --out-dir ../../packages/client-ui/src/wasm-pkg",
    "bundle-mod": "node --experimental-strip-types tools/bundle-mod.mjs",
    "validate-mod": "pnpm --filter validator-cli start -- ../../mods/reference-mod",
    "verify:js": "pnpm test:loader && pnpm validate-mod",
    "dev": "pnpm --filter client-ui dev"
  }
}
